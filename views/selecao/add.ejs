<%- include('../cabecalho.ejs')%>
<main class="container">
        <a href="/selecao/lst" class="back-link">← Voltar para Seleções</a>

        <div class="form-container">
            <h2>Cadastrar Nova Seleção</h2>

            <form method="post">
                <div class="form-group">
                    <label for="pais">País da seleção *</label>
                    <input 
                        type="text" 
                        id="pais" 
                        name="pais" 
                    >
                </div>

                <div class="form-group">
                    <label for="cores">Cores *</label>
                    <input 
                        type="text" 
                        id="cores" 
                        name="cores" 
                        placeholder="Ex: Azul, Branco"
                    >
                </div>

                <div class="form-group">
                    <label for="continente">Continente *</label>
                    <select id="continente" name="continente">
                            <option value="">Selecione</option>
                            <option value="America">América</option>
                            <option value="Africa">África</option>
                            <option value="Asia">Ásia</option>
                            <option value="Europa">Europa</option>
                            <option value="Oceania">Oceania</option>
                    </select>
                </div>
                 <div class="form-group">
                    <label for="titulosMundiais">Titulos Mundiais *</label>
                    <input 
                        type="text" 
                        id="titulosMundiais" 
                        name="titulosMundiais" 
                        placeholder="Ex: 5"
                     >
                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Cadastrar</button>
                    <a href="/selecao/lst" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
<%- include('../rodape.ejs')%>