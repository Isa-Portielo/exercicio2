<%- include('../cabecalho.ejs')%>
<main class="container">
        <a href="/selecao/lst" class="back-link">← Voltar para Seleção</a>

        <div class="form-container">
            <h2>Editar Seleção</h2>
            
            <form method="post">
              <div class="form-group">
                    <label for="id">Id da Seleção *</label>
                    <input 
                        type="text" 
                        id="id" 
                        name="id" 
                        value="<%=selecao.id%>"
                        required
                    >
                </div>
                <div class="form-group">
                    <label for="pais">País da Seleção *</label>
                    <input 
                        type="text" 
                        id="pais" 
                        name="pais" 
                        value="<%=selecao.pais%>"
                        required
                    >
                </div>

                <div class="form-group">
                    <label for="cores">Cores *</label>
                    <input 
                        type="text" 
                        id="cores" 
                        name="cores" 
                        value="<%=selecao.cores%>"
                        required
                    >
                </div>

                <div class="form-group">
                    <label for="continente">Continente *</label>
                    <input 
                        type="text" 
                        id="continente" 
                        name="continente" 
                        value="<%=selecao.continente%>"
                        required
                    >
                </div>

                 <div class="form-group">
                    <label for="titulosMundiais">Titulos mundiais*</label>
                    <input 
                        type="text" 
                        id="titulosMundiais" 
                        name="titulosMundiais" 
                        value="<%=selecao.titulosMundiais%>"
                        required
                    >
                </div>
                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Editar</button>
                    <a href="/selecao/lst" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
<%- include('../rodape.ejs')%>