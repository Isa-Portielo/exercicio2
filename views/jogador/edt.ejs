<%- include('../cabecalho.ejs')%>
<main class="container">
        <a href="/jogador/lst" class="back-link">← Voltar para Jogadores</a>

        <div class="form-container">
            <h2>Editar Jogador</h2>

            <form method="post">
              <div class="form-group">
                    <label for="id">Id do jogador*</label>
                    <input 
                        type="text" 
                        id="id" 
                        name="id" 
                        value="<%=jogador.id%>"
                        required
                    >
                </div>
                <div class="form-group">
                    <label for="nome"> Nome do Jogador *</label>
                    <input 
                        type="text" 
                        id="nome" 
                        name="nome" 
                        value="<%=jogador.nome%>"
                        required
                    >
                </div>

                <div class="form-group">
                    <label for="numero">Número*</label>
                    <input 
                        type="text" 
                        id="numero" 
                        name="numero" 
                        value="<%=jogador.numero%>"
                        required
                    >
                </div>

                <div class="form-group">
                    <label for="selecao"> Seleção *</label>
                    <input 
                        type="text" 
                        id="selecao" 
                        name="selecao" 
                        value="<%=jogador.selecao%>"
                        required
                    >
                </div>

                 <div class="form-group">
                    <label for="gols">Gols *</label>
                    <input 
                        type="text" 
                        id="gols" 
                        name="gols" 
                        value="<%=jogador.gols%>"
                        required
                    >
                </div>
                  <div class="form-group">
                    <label for="assistencias">Assistências *</label>
                    <input 
                        type="text" 
                        id="assistencias" 
                        name="assistencias" 
                        value="<%=jogador.assistencias%>"
                        required
                    >
                </div>
                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Editar</button>
                    <a href="/jogador/lst" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
<%- include('../rodape.ejs')%>